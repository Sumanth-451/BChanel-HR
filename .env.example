# Cohere
COHERE_API_KEY=your_cohere_api_key_here
COHERE_MODEL=command-r-plus-08-2024

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=hr_workflow

# Twilio (get free trial at https://www.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Public base URL for Twilio webhooks (use ngrok in dev: ngrok http 8000)
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app
# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ENV=development

# Anthropic / Claude — CSV screening path
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Sheets — SCREEN tab for CSV screening results
# Sheet ID is the long string in the Sheets URL
GOOGLE_SHEETS_ID=1MU6JlOlm4DNIVK3KykFMguBIUcV2lP749Vzcz_ALq00
